@{
    Layout = "~/Views/Shared/_LayoutAdministrative.cshtml";
}

@model UserAdministrative

@{
    ViewData["Title"] = "Editar Administrativo";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center">Editar Administrativo</h2>
            <form asp-action="EditUserAdministrative" method="post" class="mt-4">
                <input type="hidden" asp-for="@Model.UserAdministrativeId" /> <!-- Campo oculto para el ID -->

                <div class="form-group">
                    <label asp-for="@Model.NameAdministrative" class="control-label"></label>
                    <input asp-for="@Model.NameAdministrative" class="form-control" />
                    <span asp-validation-for="@Model.NameAdministrative" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="@Model.DniAdministrative" class="control-label"></label>
                    <input asp-for="@Model.DniAdministrative" class="form-control" />
                    <span asp-validation-for="@Model.DniAdministrative" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="@Model.Cellphone" class="control-label"></label>
                    <input asp-for="@Model.Cellphone" class="form-control" />
                    <span asp-validation-for="@Model.Cellphone" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="@Model.Address" class="control-label"></label>
                    <input asp-for="@Model.Address" class="form-control" />
                    <span asp-validation-for="@Model.Address" class="text-danger"></span>
                </div>

                <div class="form-group text-center">
                    <input type="submit" value="Actualizar" class="btn btn-primary" />
                    <a asp-action="ListUserAdministrative" class="btn btn-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
