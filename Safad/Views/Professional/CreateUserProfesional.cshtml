@{
    Layout = "~/Views/Shared/_LayoutCreate.cshtml";
}

@model Safad.Models.Profesional

@{
    ViewData["Title"] = "Crear Profesional";
}

<div class="container-create container mt-4">
    <h2 class="text-center">Crear Profesional</h2>
    <hr />
    <form asp-action="CreateUserProfesional" method="post">
        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label for="NameProfesional">Nombre</label>
                    <input type="text" class="form-control" id="NameProfesional" name="NameProfesional" required />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="DniProfesional">DNI</label>
                    <input type="text" class="form-control" id="DniProfesional" name="DniProfesional" required />
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group">
                    <label for="Cellphone">Celular</label>
                    <input type="text" class="form-control" id="Cellphone" name="Cellphone" required />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group">
                    <label for="Address">Dirección</label>
                    <input type="text" class="form-control" id="Address" name="Address" required />
                </div>
            </div>
        </div>

        <div class="form-group">
            <label for="TeamId">TeamId</label>
            <input type="text" class="form-control" id="TeamId" name="TeamId" required />
        </div>

        <div class="text-center">
            <button type="submit" class="btn btn-primary mt-3">Crear</button>
        </div>
    </form>
</div>
